body{
    margin:0;
    font-family:Arial, Helvetica, sans-serif;
    background:#0f172a;
    color:white;
}

.container{
    text-align:center;
    margin-top:100px;
}

.roles{
    display:flex;
    justify-content:center;
    gap:40px;
    margin-top:40px;
}

.card{
    background:#1e293b;
    padding:30px;
    width:200px;
    border-radius:10px;
    cursor:pointer;
    transition:0.3s;
}

.card:hover{
    transform:scale(1.05);
    background:#334155;
}